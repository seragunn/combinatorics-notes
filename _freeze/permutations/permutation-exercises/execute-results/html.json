    "engine": "jupyter",
    "markdown": "<script src=\"/js/permutations.js\"></script>\n<script>\n    function checkCycles(ans) {\n        return (input) => {\n            const ans_perm = new Permutation(ans);\n            const in_perm = new Permutation().parseCycles(input);\n            return in_perm.equals(ans_perm);\n        }\n    }\n    function checkCyclesFromInput(input_id) {\n        return (input) => {\n            const ans = document.getElementById(input_id).value;\n            const ans_perm = new Permutation().parseList(ans);\n            const in_perm = new Permutation().parseCycles(input);\n            return in_perm.equals(ans_perm);\n        }\n    }\n    function checkShuffle(ans) {\n        return (input) => {\n            const ans_perm = new Permutation(ans);\n            const in_perm = new Permutation().parseList(input);\n            return in_perm.equals(ans_perm);\n        }\n    }\n    function checkShuffleFromInput(input_id) {\n        return (input) => {\n            const ans = document.getElementById(input_id).value;\n            const ans_perm = new Permutation().parseCycles(ans);\n            const in_perm = new Permutation().parseList(input);\n            return in_perm.equals(ans_perm);\n        }\n    }\n    function checkProductofTranspositions(ans) {\n        return (input) => {\n            const ans_perm = new Permutation(ans);\n            const cycles = readCycles(input);\n            return cycles.every((c) => c.length == 2) && mulCycles(cycles).equals(ans_perm);\n        }\n    }\n    function checkProductofTranspositionsFromInput(input_id) {\n        return (input) => {\n            const ans = document.getElementById(input_id).value;\n            const ans_perm = new Permutation().parseCycles(ans);\n            const cycles = readCycles(input);\n            return cycles.every((c) => c.length == 2) && mulCycles(cycles).equals(ans_perm);\n        }\n    }\n    function checkSignFromInput(input_id) {\n        return (input) => {\n            const cycles = document.getElementById(input_id).value;\n            const ans = new Permutation().parseCycles(cycles).sign();\n            return input == ans;\n        }\n    }\n    function fillRandomShuffle(input_id, n) {\n        const p = randomPermutation(n);\n        document.getElementById(input_id).value = p.list;\n    }\n    function fillRandomCycles(input_id, n) {\n        const cycles = randomPermutation(n).cycles;\n        let str = \"\";\n        for(cycle of cycles) { str += \"(\" + cycle + \")\" }\n        document.getElementById(input_id).value = str;\n    }\n</script>\n\n# Exercises\n\n1. Convert $2, 12, 3, 5, 4, 9, 8, 7, 6, 10, 1, 11$ to a product of cycles and draw the associated digraph.\n\n::: {#3100c608 .cell execution_count=1}\n\n::: {.cell-output .cell-output-display execution_count=2}\n```{=html}\n<script>\nvar ID = \"NPo7uQ1u\"\n</script>\n<form class=\"mx-2 my-3 mw-100 qqquestion\"\n      name='WeaveQuestion'\n      data-id='NPo7uQ1u'\n      data-controltype=''\n      onSubmit='return false;'\n      >\n  <div class='form-group '>\n    <div class='controls'>\n      <div class=\"form\" id=\"controls_NPo7uQ1u\" correct='-1' attempts='0'>\n\n    <div style=\"padding-top: 5px\">\n    </br>\n<div class=\"input-group\"\n     aria-label=\"Input form: Check your work\">\n    <input id=\"NPo7uQ1u\"\n           type=\"text\"\n           \n           class=\"form-control qqinput\"\n           placeholder=\"Check your work\"\n           aria-label=\"Check your work\">\n</div>\n\n         </div>\n    </div>\n    <div id='NPo7uQ1u_message'\n         class='qqmessage'\n         style=\"padding-bottom: 15px\">\n    </div>\n</form>\n<script>\ndocument.getElementById('controls_NPo7uQ1u').addEventListener(\"quizquestion_answer\", (e) => {\n\t      var o = document.getElementById('controls_NPo7uQ1u')\n\t      var atts = Number(o.getAttribute(\"attempts\"))\n\t      o.setAttribute(\"correct\",  e.detail.correct);\n\t      o.setAttribute(\"attempts\", atts + 1)\n\t  }, true)\n</script>\n\n<script text='text/javascript'>\ndocument.getElementById(\"NPo7uQ1u\").addEventListener(\"change\", function() {\n  var correct = (checkCycles([2, 12, 3, 5, 4, 9, 8, 7, 6, 10, 1, 11]))(this.value);\n  var msgBox = document.getElementById('NPo7uQ1u_message');\n  \n  if(correct) {\n    msgBox.innerHTML = \"<div class='pluto-output admonition note alert alert-success'> <span>✔&nbsp; Correct </span> </div>\";\n    var explanation = document.getElementById(\"explanation_NPo7uQ1u\")\n    if (explanation != null) {\n       explanation.style.display = \"none\";\n    }\n      const correct_answer   = new CustomEvent(\"quizquestion_answer\",\n          {bubbles:true, detail:{correct: 1}}\n  );\n  this.dispatchEvent(correct_answer);\n\n  } else {\n    msgBox.innerHTML = \"<div class='pluto-output admonition alert alert-danger'> <span>Χ&nbsp; Incorrect </span> </div>\";\n    var explanation = document.getElementById(\"explanation_NPo7uQ1u\")\n    if (explanation != null) {\n       explanation.style.display = \"block\";\n    }\n      const incorrect_answer = new CustomEvent(\"quizquestion_answer\",\n           {bubbles:true, detail:{correct: 0}}\n  );\n  this.dispatchEvent(incorrect_answer);\n\n  }\n\n});\n\n</script>\n```\n:::\n:::\n\n\n::: {.callout-tip collapse=\"true\"}\n## Hint\nReference: @sec-cycle-decomposition\n\n* start with 1\n    * there is a 2 in position 1\n    * there is a 12 in position 2\n    * keep going...x in position 12...until you get back to 1\n* write down the first cycle $(1, 2, 12, \\dots)$ (don't repeat the $1$ at the end)\n* do the same procedure with the next number which hasn't been seen so far (i.e. 3)\n* keep going until every number is part of a cycle\n* optionally, throw away cycles of length 1\n:::\n\n2. Convert $(1,8,12)(2,3,6,7,9)(4,10,11)$ to a shuffle of $1,\\dots,12$\n\n::: {#4a7d9f0f .cell execution_count=2}\n\n::: {.cell-output .cell-output-display execution_count=3}\n```{=html}\n<script>\nvar ID = \"BIdNOrlB\"\n</script>\n<form class=\"mx-2 my-3 mw-100 qqquestion\"\n      name='WeaveQuestion'\n      data-id='BIdNOrlB'\n      data-controltype=''\n      onSubmit='return false;'\n      >\n  <div class='form-group '>\n    <div class='controls'>\n      <div class=\"form\" id=\"controls_BIdNOrlB\" correct='-1' attempts='0'>\n\n    <div style=\"padding-top: 5px\">\n    </br>\n<div class=\"input-group\"\n     aria-label=\"Input form: Check your work\">\n    <input id=\"BIdNOrlB\"\n           type=\"text\"\n           \n           class=\"form-control qqinput\"\n           placeholder=\"Check your work\"\n           aria-label=\"Check your work\">\n</div>\n\n         </div>\n    </div>\n    <div id='BIdNOrlB_message'\n         class='qqmessage'\n         style=\"padding-bottom: 15px\">\n    </div>\n</form>\n<script>\ndocument.getElementById('controls_BIdNOrlB').addEventListener(\"quizquestion_answer\", (e) => {\n\t      var o = document.getElementById('controls_BIdNOrlB')\n\t      var atts = Number(o.getAttribute(\"attempts\"))\n\t      o.setAttribute(\"correct\",  e.detail.correct);\n\t      o.setAttribute(\"attempts\", atts + 1)\n\t  }, true)\n</script>\n\n<script text='text/javascript'>\ndocument.getElementById(\"BIdNOrlB\").addEventListener(\"change\", function() {\n  var correct = (checkShuffle([[1,8,12],[2,3,6,7,9],[4,10,11]]))(this.value);\n  var msgBox = document.getElementById('BIdNOrlB_message');\n  \n  if(correct) {\n    msgBox.innerHTML = \"<div class='pluto-output admonition note alert alert-success'> <span>✔&nbsp; Correct </span> </div>\";\n    var explanation = document.getElementById(\"explanation_BIdNOrlB\")\n    if (explanation != null) {\n       explanation.style.display = \"none\";\n    }\n      const correct_answer   = new CustomEvent(\"quizquestion_answer\",\n          {bubbles:true, detail:{correct: 1}}\n  );\n  this.dispatchEvent(correct_answer);\n\n  } else {\n    msgBox.innerHTML = \"<div class='pluto-output admonition alert alert-danger'> <span>Χ&nbsp; Incorrect </span> </div>\";\n    var explanation = document.getElementById(\"explanation_BIdNOrlB\")\n    if (explanation != null) {\n       explanation.style.display = \"block\";\n    }\n      const incorrect_answer = new CustomEvent(\"quizquestion_answer\",\n           {bubbles:true, detail:{correct: 0}}\n  );\n  this.dispatchEvent(incorrect_answer);\n\n  }\n\n});\n\n</script>\n```\n:::\n:::\n\n\n::: {.callout-tip collapse=\"true\"}\n## Hint\nReference: @sec-cycle-multiplication\n\nSince the cycles are disjoint (don't share any numbers), the procedure here is:\n\n* look for each number from 1 to 12\n* write down the number following it in its cycle (e.g. 1 is followed by 8 so we write an 8 in the first position of the shuffle, 2 is followed by 3, 3 by 6, etc.)\n* if a number does not appear (i.e. 5), then the permutation leaves it unchanged and it remains in its starting position (so you should have a 5 in position 5 at the end)\n:::\n\n3. Show that $(12)(23)(34)(23)(12) = (14)$ by drawing the braid diagram.\n\n4. Compute the sign of the permutations in 1. and 2.\n\n::: {layout-ncol=2 .quiz-question-side-by-side}\n\n::: {#b33bc32a .cell execution_count=3}\n\n::: {.cell-output .cell-output-display execution_count=4}\n```{=html}\n<script>\nvar ID = \"me9w2SVF\"\n</script>\n<form class=\"mx-2 my-3 mw-100 qqquestion\"\n      name='WeaveQuestion'\n      data-id='me9w2SVF'\n      data-controltype=''\n      onSubmit='return false;'\n      >\n  <div class='form-group '>\n    <div class='controls'>\n      <div class=\"form\" id=\"controls_me9w2SVF\" correct='-1' attempts='0'>\n\n    <div style=\"padding-top: 5px\">\n     Problem 1:   <select name=\"select_me9w2SVF\"\n          id=\"select_me9w2SVF\"\n          aria-label=\"Make a selection\"> TTT\n     <option value=\"0\"\n             selected=\"selected\">Choose...</option>\n     <option value=\"1\"> -1 \n</option>\n     <option value=\"2\"> 1 \n</option>\n  </select>\n<label for=\"select_me9w2SVF\"\n       style=\"left: -100vw; position: absolute;\">Make a selection</label>\n \n\n         </div>\n    </div>\n    <div id='me9w2SVF_message'\n         class='qqmessage'\n         style=\"padding-bottom: 15px\">\n    </div>\n</form>\n<script>\ndocument.getElementById('controls_me9w2SVF').addEventListener(\"quizquestion_answer\", (e) => {\n\t      var o = document.getElementById('controls_me9w2SVF')\n\t      var atts = Number(o.getAttribute(\"attempts\"))\n\t      o.setAttribute(\"correct\",  e.detail.correct);\n\t      o.setAttribute(\"attempts\", atts + 1)\n\t  }, true)\n</script>\n\n<script text='text/javascript'>\n      function callback(element, iterator) {\n\t  element.addEventListener(\"change\", function() {\n\t      var a = [];\n\t      var selectors = document.querySelectorAll('[id ^= \"select_me9w2SVF\"]');\n\t      Array.prototype.forEach.call(selectors, function (element, iterator) {\n\t\t a.push(element.value);\n\t      })\n              var b = ['2'];\n              // https://stackoverflow.com/questions/7837456/how-to-compare-arrays-in-javascript\n              var correct =  (a.length === b.length && a.find((v,i) => v !== b[i]) === undefined)\n              var msgBox = document.getElementById('me9w2SVF_message');\n              \n  if(correct) {\n    msgBox.innerHTML = \"<div class='pluto-output admonition note alert alert-success'> <span>✔&nbsp; Correct </span> </div>\";\n    var explanation = document.getElementById(\"explanation_me9w2SVF\")\n    if (explanation != null) {\n       explanation.style.display = \"none\";\n    }\n      const correct_answer   = new CustomEvent(\"quizquestion_answer\",\n          {bubbles:true, detail:{correct: 1}}\n  );\n  this.dispatchEvent(correct_answer);\n\n  } else {\n    msgBox.innerHTML = \"<div class='pluto-output admonition alert alert-danger'> <span>Χ&nbsp; Not yet </span> </div>\";\n    var explanation = document.getElementById(\"explanation_me9w2SVF\")\n    if (explanation != null) {\n       explanation.style.display = \"block\";\n    }\n      const incorrect_answer = new CustomEvent(\"quizquestion_answer\",\n           {bubbles:true, detail:{correct: 0}}\n  );\n  this.dispatchEvent(incorrect_answer);\n\n  }\n\n\t  })\n      }\n      Array.prototype.forEach.call(document.querySelectorAll('[id ^= \"select_me9w2SVF\"]'), callback);\n\n</script>\n```\n:::\n:::\n\n\n::: {#31164e27 .cell execution_count=4}\n\n::: {.cell-output .cell-output-display execution_count=5}\n```{=html}\n<script>\nvar ID = \"DSQMOUw8\"\n</script>\n<form class=\"mx-2 my-3 mw-100 qqquestion\"\n      name='WeaveQuestion'\n      data-id='DSQMOUw8'\n      data-controltype=''\n      onSubmit='return false;'\n      >\n  <div class='form-group '>\n    <div class='controls'>\n      <div class=\"form\" id=\"controls_DSQMOUw8\" correct='-1' attempts='0'>\n\n    <div style=\"padding-top: 5px\">\n     Problem 2:   <select name=\"select_DSQMOUw8\"\n          id=\"select_DSQMOUw8\"\n          aria-label=\"Make a selection\"> TTT\n     <option value=\"0\"\n             selected=\"selected\">Choose...</option>\n     <option value=\"1\"> 1 \n</option>\n     <option value=\"2\"> -1 \n</option>\n  </select>\n<label for=\"select_DSQMOUw8\"\n       style=\"left: -100vw; position: absolute;\">Make a selection</label>\n \n\n         </div>\n    </div>\n    <div id='DSQMOUw8_message'\n         class='qqmessage'\n         style=\"padding-bottom: 15px\">\n    </div>\n</form>\n<script>\ndocument.getElementById('controls_DSQMOUw8').addEventListener(\"quizquestion_answer\", (e) => {\n\t      var o = document.getElementById('controls_DSQMOUw8')\n\t      var atts = Number(o.getAttribute(\"attempts\"))\n\t      o.setAttribute(\"correct\",  e.detail.correct);\n\t      o.setAttribute(\"attempts\", atts + 1)\n\t  }, true)\n</script>\n\n<script text='text/javascript'>\n      function callback(element, iterator) {\n\t  element.addEventListener(\"change\", function() {\n\t      var a = [];\n\t      var selectors = document.querySelectorAll('[id ^= \"select_DSQMOUw8\"]');\n\t      Array.prototype.forEach.call(selectors, function (element, iterator) {\n\t\t a.push(element.value);\n\t      })\n              var b = ['1'];\n              // https://stackoverflow.com/questions/7837456/how-to-compare-arrays-in-javascript\n              var correct =  (a.length === b.length && a.find((v,i) => v !== b[i]) === undefined)\n              var msgBox = document.getElementById('DSQMOUw8_message');\n              \n  if(correct) {\n    msgBox.innerHTML = \"<div class='pluto-output admonition note alert alert-success'> <span>✔&nbsp; Correct </span> </div>\";\n    var explanation = document.getElementById(\"explanation_DSQMOUw8\")\n    if (explanation != null) {\n       explanation.style.display = \"none\";\n    }\n      const correct_answer   = new CustomEvent(\"quizquestion_answer\",\n          {bubbles:true, detail:{correct: 1}}\n  );\n  this.dispatchEvent(correct_answer);\n\n  } else {\n    msgBox.innerHTML = \"<div class='pluto-output admonition alert alert-danger'> <span>Χ&nbsp; Not yet </span> </div>\";\n    var explanation = document.getElementById(\"explanation_DSQMOUw8\")\n    if (explanation != null) {\n       explanation.style.display = \"block\";\n    }\n      const incorrect_answer = new CustomEvent(\"quizquestion_answer\",\n           {bubbles:true, detail:{correct: 0}}\n  );\n  this.dispatchEvent(incorrect_answer);\n\n  }\n\n\t  })\n      }\n      Array.prototype.forEach.call(document.querySelectorAll('[id ^= \"select_DSQMOUw8\"]'), callback);\n\n</script>\n```\n:::\n:::\n\n\n:::\n\n::: {.callout-tip collapse=\"true\"}\n## Hint\nReference: @sec-sign-algorithm\n\nRegardless of whether the cycles are disjoint or not (here they are), odd cycles are even and even cycles are odd (in terms of number of swaps). So multiply $1$ for each odd length cycle and $-1$ for each even length cycle. For example, $(1, 8, 2)$ has an odd length (even number of swaps) so we multiply $+1$ for it.\n:::\n\n5. Write $(182635)$ as a product of transpositions.\n\n::: {#fbb84dcf .cell execution_count=5}\n\n::: {.cell-output .cell-output-display execution_count=6}\n```{=html}\n<script>\nvar ID = \"DkYCmuUM\"\n</script>\n<form class=\"mx-2 my-3 mw-100 qqquestion\"\n      name='WeaveQuestion'\n      data-id='DkYCmuUM'\n      data-controltype=''\n      onSubmit='return false;'\n      >\n  <div class='form-group '>\n    <div class='controls'>\n      <div class=\"form\" id=\"controls_DkYCmuUM\" correct='-1' attempts='0'>\n\n    <div style=\"padding-top: 5px\">\n    </br>\n<div class=\"input-group\"\n     aria-label=\"Input form: Check your work\">\n    <input id=\"DkYCmuUM\"\n           type=\"text\"\n           \n           class=\"form-control qqinput\"\n           placeholder=\"Check your work\"\n           aria-label=\"Check your work\">\n</div>\n\n         </div>\n    </div>\n    <div id='DkYCmuUM_message'\n         class='qqmessage'\n         style=\"padding-bottom: 15px\">\n    </div>\n</form>\n<script>\ndocument.getElementById('controls_DkYCmuUM').addEventListener(\"quizquestion_answer\", (e) => {\n\t      var o = document.getElementById('controls_DkYCmuUM')\n\t      var atts = Number(o.getAttribute(\"attempts\"))\n\t      o.setAttribute(\"correct\",  e.detail.correct);\n\t      o.setAttribute(\"attempts\", atts + 1)\n\t  }, true)\n</script>\n\n<script text='text/javascript'>\ndocument.getElementById(\"DkYCmuUM\").addEventListener(\"change\", function() {\n  var correct = (checkProductofTranspositions([[1,8,2,6,3,5]]))(this.value);\n  var msgBox = document.getElementById('DkYCmuUM_message');\n  \n  if(correct) {\n    msgBox.innerHTML = \"<div class='pluto-output admonition note alert alert-success'> <span>✔&nbsp; Correct </span> </div>\";\n    var explanation = document.getElementById(\"explanation_DkYCmuUM\")\n    if (explanation != null) {\n       explanation.style.display = \"none\";\n    }\n      const correct_answer   = new CustomEvent(\"quizquestion_answer\",\n          {bubbles:true, detail:{correct: 1}}\n  );\n  this.dispatchEvent(correct_answer);\n\n  } else {\n    msgBox.innerHTML = \"<div class='pluto-output admonition alert alert-danger'> <span>Χ&nbsp; Incorrect </span> </div>\";\n    var explanation = document.getElementById(\"explanation_DkYCmuUM\")\n    if (explanation != null) {\n       explanation.style.display = \"block\";\n    }\n      const incorrect_answer = new CustomEvent(\"quizquestion_answer\",\n           {bubbles:true, detail:{correct: 0}}\n  );\n  this.dispatchEvent(incorrect_answer);\n\n  }\n\n});\n\n</script>\n```\n:::\n:::\n\n\n::: {.callout-tip collapse=\"true\"}\n## Hint\nReference: @thm-product-of-transpositions\n\nThe rule is like $(a,b,c,d) = (a, b)(b, c)(c, d)$. The transpositions are adjacent pairs.\n:::\n\n::: {.content-visible when-format=html}\n### Additional practice {.unnumbered}\n\n::: panel-tabset\n\n### Shuffle to Cycles\n\n::: {.mx-2}\n<label for=\"n-shuffle\">n:</label>\n<input type=\"number\" id=\"n-shuffle\" value=\"10\">\n<input type=\"button\" id=\"shuffle-randomize\" value=\"Randomize\" onclick=\"fillRandomShuffle('shuffle-input', document.getElementById('n-shuffle').value)\" class=\"randomize_button\">\n<br><br>\n<input id=\"shuffle-input\" class=\"form-control\" placeholder=\"Shuffle\">\n:::\n\n::: {#e694a55c .cell execution_count=6}\n\n::: {.cell-output .cell-output-display execution_count=7}\n```{=html}\n<script>\nvar ID = \"NUoN0cQI\"\n</script>\n<form class=\"mx-2 my-3 mw-100 qqquestion\"\n      name='WeaveQuestion'\n      data-id='NUoN0cQI'\n      data-controltype=''\n      onSubmit='return false;'\n      >\n  <div class='form-group '>\n    <div class='controls'>\n      <div class=\"form\" id=\"controls_NUoN0cQI\" correct='-1' attempts='0'>\n\n    <div style=\"padding-top: 5px\">\n    </br>\n<div class=\"input-group\"\n     aria-label=\"Input form: Check your work\">\n    <input id=\"NUoN0cQI\"\n           type=\"text\"\n           \n           class=\"form-control qqinput\"\n           placeholder=\"Check